node_modules
# Synced from the repo root at build time (see scripts/sync-generated.mjs).
src/metagraphed-api.ts
src/metagraphed-client.ts

# dist IS committed here (unlike the root .gitignore's blanket `dist` rule) --
# apps/ui consumes this package as a live workspace link, and Cloudflare
# Workers Builds' live deploy must never depend on rebuilding it (see the
# "Build packages/client (drift check)" step in .github/workflows/validate.yml
# for why). Un-ignore it explicitly; CI's drift check keeps it honest.
!dist
!dist/**
