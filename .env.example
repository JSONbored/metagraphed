# Public base URL of the Metagraphed backend API (default: https://metagraph.sh).
VITE_API_BASE=https://metagraph.sh

# Optional icon proxy/resizer endpoint. When set, BrandIcon will prefer this
# source over DuckDuckGo / Google S2 / GitHub avatars. The backend service
# (lives outside this repo) must implement:
#
#   GET {VITE_ICON_PROXY_URL}?host={domain}&size={px}&theme={light|dark}
#     → 200 image/png|svg (square, width/height >= size)
#     → 404 if no usable source found
#   Cache-Control: public, max-age=2592000, immutable + ETag
#
# Leave blank to use the default DDG/S2 fallback chain.
VITE_ICON_PROXY_URL=
